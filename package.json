{
  "name": "twinmind",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite frontend --config frontend/vite.config.js",
    "dev:backend": "node backend/index.js",
    "build": "vite build frontend --config frontend/vite.config.js",
    "preview": "vite preview frontend --config frontend/vite.config.js",
    "start": "node backend/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1"
  }
}




